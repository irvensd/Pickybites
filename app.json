{
  "expo": {
    "name": "PickyBites",
    "slug": "pickybites",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "pickybites",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/images/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAFAFA"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.pickybites.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#C96B75",
        "foregroundImage": "./assets/images/logo.png"
      },
      "package": "com.pickybites.app",
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [{ "scheme": "pickybites" }],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ],
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "PickyBites needs access to your photos to attach food images to reviews."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "PickyBites uses your location to find restaurants near you."
        }
      ],
      "expo-asset",
      "expo-font",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/logo.png",
          "color": "#C96B75"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e870b8ed-b8b7-4cd5-abbf-f01725d49b6f"
      }
    }
  }
}
