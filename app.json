{
  "expo": {
    "name": "Savr",
    "slug": "savr",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "savr",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAFAF8"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.savr.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#A85D3F",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "package": "com.savr.app",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Savr needs access to your photos to attach food images to reviews."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Savr uses your location to tag restaurants in your city."
        }
      ],
      "expo-asset",
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e870b8ed-b8b7-4cd5-abbf-f01725d49b6f"
      }
    }
  }
}
